{
  "uid": "devsecops-kubernetes",
  "title": "DevSecOps - Kubernetes Monitoring",
  "tags": ["devsecops", "kubernetes", "pfe"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Pods Running",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "count(kube_pod_status_phase{phase=\"Running\",namespace=\"devsecops-platform\"})", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 1 }, { "color": "green", "value": 3 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pods Pending / Failed",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "count(kube_pod_status_phase{phase=~\"Pending|Failed|Unknown\",namespace=\"devsecops-platform\"}) or vector(0)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 3 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Pod Restarts",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(kube_pod_container_status_restarts_total{namespace=\"devsecops-platform\"}) or vector(0)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 3 }, { "color": "red", "value": 10 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Nodes Ready",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "count(kube_node_status_condition{condition=\"Ready\",status=\"true\"}) or vector(0)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Pod Status Overview",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kube_pod_status_phase{namespace=\"devsecops-platform\"}",
          "refId": "A",
          "legendFormat": "{{pod}} - {{phase}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "phase" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "Running": { "color": "green", "index": 0 }, "Pending": { "color": "orange", "index": 1 }, "Failed": { "color": "red", "index": 2 } } }
                ]
              }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "sortBy": [] },
      "transformations": [
        { "id": "labelsToFields", "options": { "valueLabel": "phase" } },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Value": true, "__name__": true }, "indexByName": {}, "renameByName": { "namespace": "Namespace", "pod": "Pod", "phase": "Phase" } } }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Pod Restarts Over Time",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "increase(kube_pod_container_status_restarts_total{namespace=\"devsecops-platform\"}[1h])",
          "legendFormat": "{{pod}} / {{container}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "lineInterpolation": "linear", "lineWidth": 1, "fillOpacity": 70, "showPoints": "never" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU Usage by Pod",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"devsecops-platform\",container!=\"\",container!=\"POD\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Memory Usage by Pod",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"devsecops-platform\",container!=\"\",container!=\"POD\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Deployments Available",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 22 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "count(kube_deployment_status_replicas_available{namespace=\"devsecops-platform\"} > 0) or vector(0)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "PVC Bound",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 22 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "count(kube_persistentvolumeclaim_status_phase{namespace=\"devsecops-platform\",phase=\"Bound\"}) or vector(0)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Crash Loop Pods",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 22 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "count(rate(kube_pod_container_status_restarts_total{namespace=\"devsecops-platform\"}[1h]) > 0) or vector(0)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" }
    }
  ]
}
