# ==============================================================================
# ENVIRONMENT VARIABLES - DevSecOps Project
# ==============================================================================

# ==============================================================================
# APPLICATION
# ==============================================================================
APP_NAME=devsecops-app
APP_ENV=development
APP_DEBUG=true
APP_PORT=5000
APP_URL=http://localhost

# ==============================================================================
# DATABASE
# ==============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=appdb
DB_DRIVER=postgresql

# ==============================================================================
# FRONTEND
# ==============================================================================
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:5000/api

# ==============================================================================
# DOCKER REGISTRY
# ==============================================================================
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=yourusername
DOCKER_PASSWORD=yourtoken
DOCKER_REGISTRY_URL=yourusername

# ==============================================================================
# KUBERNETES
# ==============================================================================
K8S_NAMESPACE=default
K8S_CLUSTER_NAME=minikube
K8S_CONTEXT=minikube

# ==============================================================================
# JENKINS
# ==============================================================================
JENKINS_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_TOKEN=changeme

# ==============================================================================
# MONITORING (PROMETHEUS / GRAFANA)
# ==============================================================================
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# ==============================================================================
# ALERTMANAGER
# ==============================================================================
ALERTMANAGER_PORT=9093
ALERT_EMAIL_FROM=alerts@company.com
ALERT_EMAIL_TO=devops@company.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ==============================================================================
# VAULT (SECRETS MANAGEMENT)
# ==============================================================================
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=s.changeme
VAULT_NAMESPACE=dev

# ==============================================================================
# LOGGING
# ==============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ==============================================================================
# SECURITY
# ==============================================================================
ENABLE_HTTPS=false
TLS_CERT_PATH=/etc/tls/certs/tls.crt
TLS_KEY_PATH=/etc/tls/certs/tls.key
ENABLE_RBAC=true

# ==============================================================================
# BACKUP
# ==============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # 2h du matin
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups

# ==============================================================================
# SONARQUBE
# ==============================================================================
SONARQUBE_HOST=http://localhost:9000
SONARQUBE_TOKEN=changeme
SONAR_PROJECT_KEY=my-app

# ==============================================================================
# TRIVY
# ==============================================================================
TRIVY_SEVERITY=HIGH,CRITICAL
TRIVY_SCAN_DIR=./

# ==============================================================================
# CUSTOM
# ==============================================================================
# Ajoutez vos variables personnalisées ici
